{
	"name": "n8n-nodes-encelade",
	"version": "0.1.4",
	"description": "n8n community node for Encelade — generate, manage, and react to AI-generated presentations via the Encelade API",
	"license": "MIT",
	"homepage": "https://www.encelade.ai",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"encelade",
		"presentation",
		"slides",
		"ai",
		"deck"
	],
	"author": {
		"name": "n",
		"email": "nastiasplin@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/encelade-ai/n8n-nodes-encelade.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/EnceladeApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Encelade/Encelade.node.js",
			"dist/nodes/Encelade/EnceladeTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.29.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"publishConfig": {
		"access": "public"
	}
}
